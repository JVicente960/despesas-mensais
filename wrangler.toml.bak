# =====================================================================
# wrangler.toml · configuração da Cloudflare (Pages + D1)
# Usado tanto no deploy quanto no teste local (wrangler pages dev).
# =====================================================================

name = "aurora"
compatibility_date = "2024-09-01"

# Pasta que contém o index.html (raiz do projeto, neste caso "." mesmo).
pages_build_output_dir = "."

# Banco D1 — cole o database_id que aparece ao rodar:
#   wrangler d1 create aurora-db
[[d1_databases]]
binding = "aurora_db"
database_name = "aurora-db"
database_id = "e8358982-cff2-4a12-bda5-cff4d86b9d7f"
